{
  "name": "expense-tracker-frontend",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "build:prod": "tsc && VITE_API_URL=$npm_package_config_prodApiUrl vite build",
    "build:staging": "tsc && VITE_API_URL=$npm_package_config_stagingApiUrl vite build"
  },
  "config": {
    "prodApiUrl": "https://your-production-api.com/api",
    "stagingApiUrl": "https://staging-api.your-domain.com/api"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "recharts": "^3.7.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "typescript": "^5.2.0",
    "vite": "^5.0.0"
  }
}
