# Expense Tracker Frontend - Environment Configuration
# Copy this file to .env.local and update values for your environment

# Backend API Base URL
# For development: http://localhost:8080/api
# For production: https://api.yourdomain.com/api
# For staging: https://staging-api.yourdomain.com/api
VITE_API_URL=http://localhost:8080/api

# Debug mode (true or false)
VITE_DEBUG=false
